{
  "name": "@knight-lab/timeline-ng",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NUKnightLab/timeline-ng.git",
    "directory": "packages/player"
  },
  "homepage": "https://github.com/NUKnightLab/timeline-ng#readme",
  "bugs": "https://github.com/NUKnightLab/timeline-ng/issues",
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
