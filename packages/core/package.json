{
  "name": "@knight-lab/timeline-ng-core",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NUKnightLab/timeline-ng.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/NUKnightLab/timeline-ng#readme",
  "bugs": "https://github.com/NUKnightLab/timeline-ng/issues",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schema/timeline.schema.json": "./schema/timeline.schema.json"
  },
  "files": [
    "dist",
    "schema"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json && node scripts/schema.mjs",
    "build:schema": "node scripts/schema.mjs",
    "dev": "vite build --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "@types/node": "^26.1.0",
    "ajv": "^8.20.0",
    "ts-json-schema-generator": "^2.9.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "dompurify": "^3.2.0"
  }
}
