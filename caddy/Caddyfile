# HTTPS for browser access — cert generated by mkcert, trusted by both browser and PDS
devnet.internal {
  tls /certs/devnet.internal.pem /certs/devnet.internal-key.pem

  route /client-metadata.json {
    header Content-Type application/json
    header Access-Control-Allow-Origin *
    file_server {
      root /srv
    }
  }

  route {
    reverse_proxy http://pds:3000
  }
}

# HTTP on port 80 for any PDS-internal fallback
:80 {
  route /client-metadata.json {
    header Content-Type application/json
    header Access-Control-Allow-Origin *
    file_server {
      root /srv
    }
  }

  route {
    reverse_proxy http://pds:3000
  }
}
